<% last_ball = @current_game.drawn_numbers.last %>

<div class="max-w-6xl mx-auto">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <%# Left panel: controls + ball display + drawn history %>
    <div class="lg:col-span-1 space-y-6">

      <%# Ball display %>
      <div id="drawn-ball" class="bg-white rounded-xl shadow p-6 flex justify-center" data-controller="ball">
        <%= render "shared/ball_display", ball: last_ball, game: @current_game %>
      </div>

      <%# Controls %>
      <div class="bg-white rounded-xl shadow p-4 space-y-3 no-print">
        <% if @current_game.status == "active" %>
          <%= button_to "Draw Ball", draw_game_path, method: :post,
                class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-4 rounded-lg text-lg" %>
        <% else %>
          <div class="text-center text-red-600 font-semibold py-2">Game over — all balls drawn!</div>
        <% end %>

        <%= button_to "Add Card", bingo_cards_path, method: :post,
              class: "w-full bg-green-600 hover:bg-green-700 text-white font-semibold py-2 px-4 rounded-lg" %>

        <%= link_to "Print Cards", bingo_cards_path, target: "_blank",
              class: "block w-full text-center bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-2 px-4 rounded-lg" %>
      </div>

      <%# Remaining count %>
      <div class="text-center">
        <%= render "shared/remaining_count", game: @current_game %>
      </div>

      <%# Drawn history %>
      <div id="drawn-history" class="bg-white rounded-xl shadow p-4">
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">Drawn Numbers</h2>
        <%= render "shared/drawn_list", game: @current_game %>
      </div>
    </div>

    <%# Right panel: bingo cards %>
    <div class="lg:col-span-2">
      <div class="flex items-center justify-between mb-4 no-print">
        <h2 class="text-lg font-semibold text-gray-700">
          Cards (<%= @bingo_cards.size %>)
        </h2>
      </div>

      <div id="cards-container" class="flex flex-wrap gap-4">
        <% @bingo_cards.each do |card| %>
          <%= render "shared/bingo_card", card: card, drawn_numbers: @current_game.drawn_numbers %>
        <% end %>

        <% if @bingo_cards.empty? %>
          <p class="text-gray-400 italic text-sm">No cards yet — click "Add Card" to generate one.</p>
        <% end %>
      </div>
    </div>

  </div>
</div>
