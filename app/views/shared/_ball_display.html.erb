<% if ball %>
  <div class="flex flex-col items-center">
    <div class="w-28 h-28 rounded-full bg-blue-600 text-white flex flex-col items-center justify-center shadow-lg">
      <span class="text-sm font-bold uppercase tracking-widest"><%= game.ball_letter(ball) %></span>
      <span class="text-4xl font-black leading-none"><%= ball %></span>
    </div>
    <p class="mt-2 text-sm text-gray-500">Last drawn</p>
  </div>
<% else %>
  <div class="flex flex-col items-center">
    <div class="w-28 h-28 rounded-full bg-gray-200 border-2 border-dashed border-gray-400 flex items-center justify-center">
      <span class="text-gray-400 text-sm">No ball yet</span>
    </div>
  </div>
<% end %>
