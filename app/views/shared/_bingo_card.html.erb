<div id="bingo-card-<%= card.id %>" class="inline-block">
  <div class="border-2 border-blue-700 rounded-lg overflow-hidden shadow-md w-64">
    <div class="text-center text-sm text-gray-500 py-1 bg-gray-100 font-medium"><%= card.label %></div>
    <table class="w-full border-collapse">
      <thead>
        <tr>
          <% BingoCard::HEADERS.each do |letter| %>
            <th class="bg-blue-700 text-white text-center py-2 text-lg font-bold border border-blue-800"><%= letter %></th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% 5.times do |row| %>
          <tr>
            <% 5.times do |col| %>
              <% number = card.grid[col][row] %>
              <% is_free = number.nil? %>
              <% is_marked = !is_free && drawn_numbers.include?(number) %>
              <td class="border border-gray-200 text-center py-2 text-sm font-semibold
                         <%= is_free ? 'bg-green-100 text-green-700' : '' %>
                         <%= is_marked ? 'bg-blue-200 text-blue-900' : 'text-gray-800' %>">
                <% if is_free %>
                  <span class="text-xs font-bold">FREE</span>
                <% else %>
                  <%= number %>
                <% end %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
